# --- Storage ---
# SQLite database file (lives in the /data volume in Docker)
DATABASE_PATH=./data/mytube.db
# Root of downloaded media (videos, thumbs, subs)
MEDIA_ROOT=./media

# --- Server ---
PORT=3000
# Public origin used when generating the bookmarklet / absolute links
ORIGIN=http://localhost:3000

# --- Downloads ---
# Default max height; per-download override available in the UI
DEFAULT_MAX_HEIGHT=1080
# Max concurrent yt-dlp downloads
MAX_CONCURRENT_DOWNLOADS=2

# --- Scheduler ---
# RSS poll interval in minutes (jittered)
RSS_POLL_INTERVAL_MIN=30
# Feed items older than this many days auto-expire if not acted on
FEED_ITEM_EXPIRY_DAYS=30

# --- Optional: Recommended feed (Playwright / Chromium) ---
# When false, no browser is installed or launched.
RECOMMENDED_FEED_ENABLED=false

# --- Optional: YouTube watch-history write-back ---
# Requires the recommended-feed cookies to be uploaded.
HISTORY_SYNC_ENABLED=false

# --- Auth (REQUIRED before exposing MyTube publicly) ---
# Auth turns on as soon as EITHER of the next two is set. With neither, MyTube
# is open (LAN-only mode). Use a long random value for the token.
#   generate one: openssl rand -hex 32
# AUTH_TOKEN=            # master bearer token + break-glass browser login
# AUTH_PASSWORD=         # password for the browser login page (optional)
# Cookie-signing secret; auto-generated + persisted in /data if unset.
# AUTH_SECRET=
# Force the Secure flag on the session cookie. Defaults to on when ORIGIN is https.
# AUTH_COOKIE_SECURE=true
